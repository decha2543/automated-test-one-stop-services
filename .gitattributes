# -----------------------------------------------------------------------------
# 1. Global Default
# -----------------------------------------------------------------------------
* text=auto eol=lf

# -----------------------------------------------------------------------------
# 2. Windows Scripts (ข้อยกเว้นสำคัญ)
# -----------------------------------------------------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# -----------------------------------------------------------------------------
# 3. Source Code & Documentation (Python, Markdown)
# -----------------------------------------------------------------------------
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf

# -----------------------------------------------------------------------------
# 4. Binary Files
# -----------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
*.pyc binary
*.pyd binary
