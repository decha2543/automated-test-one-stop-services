# =============================================================================
# Tool plugin — standalone .gitignore (template)
# Copy this to your tool's root when creating a new portable tool plugin.
# =============================================================================

# Generated artefacts (regenerated by sync-projects.ts — never hand-edit)
docker-compose.yml
# tsconfig.json  # uncomment for node tools with tsconfigGen

# Dependencies
node_modules/
.venv/
__pycache__/

# Test outputs & caches
outputs/
**/test-results/

# Real projects are workspace-specific and NOT committed; only the
# *-template-example scaffolds ship with the tool. Re-include the directory
# chain first — git will not descend into an excluded dir to re-include a
# child, so a bare `projects/` would also hide the template-examples.
projects/**
!projects/**/
!projects/**/*-template-example/**

# Environment files (track templates only)
.env
.env.*
!.env.template

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# TypeScript build cache
**/*.tsbuildinfo

# Temp / scratch
_tmp*
_scratch*
*.tmp
