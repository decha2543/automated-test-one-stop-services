  "private": true,
  "scripts": {
    "updater": "pnpm up -i -L -r",
    "check": "biome check . && biome format --write .",
    "lint": "biome lint .",
    "md:check": "markdownlint-cli2 \"**/*.md\"",
    "md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@evilmartians/lefthook": "^2.1.9",
    "@types/node": "^26.1.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "4.1.9",
    "dayjs": "^1.11.21",
    "fast-check": "^4.8.0",
    "markdownlint-cli2": "0.23.0",
    "prompts": "^2.4.2",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "zod": "^4.4.3"
  },
  "volta": {
    "node": "26.4.0",
    "pnpm": "11.10.0"
  }
}
