# Tool versions - single source of truth shared by setup-windows.bat and
# setup-linux.sh. Format: KEY=value, one per line, no spaces around '='.
# Lines starting with '#' are comments (skipped by both parsers).
#
# Node runtime authority is the Volta pin in package.json ("volta".node).
# Keep NODE_VERSION below in sync with that pin.
NODE_VERSION=25.9.0
PYTHON_VERSION=3.14
