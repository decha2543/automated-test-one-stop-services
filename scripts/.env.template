# =============================================================================
# Google Sheet usage logging (OPTIONAL, best-effort — never blocks a test run).
# To enable: upload credentials.json via the Hub (Projects -> scripts/.env card),
# then set SPREADSHEET_ID below. If credentials or SPREADSHEET_ID are missing,
# logging is skipped silently (not an error).
# =============================================================================

# "true" = always log without asking. Blank = the CLI asks (defaults to No).
FORCE_TRACK=""

# Target sheet tab name. Optional — defaults to "logs" when left blank.
SHEET_NAME=""

# Google Sheet ID to append rows to. REQUIRED to enable logging.
SPREADSHEET_ID=""
